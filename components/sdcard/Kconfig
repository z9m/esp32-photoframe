config HAS_SDCARD
    bool
    default n
    help
        Automatically enabled when an SD card driver is selected.
        This flag is used to conditionally compile SD card-related code.

config SDCARD_DRIVER_SDIO
    bool "SDIO SD Card Driver"
    select HAS_SDCARD
    help
        Use SDIO interface for SD card (4-bit mode).
        Typically used on boards with dedicated SDMMC pins.

        This is automatically selected by board drivers that use SDIO.

config SDCARD_DRIVER_SPI
    bool "SPI SD Card Driver"
    select HAS_SDCARD
    help
        Use SPI interface for SD card.
        More flexible pin assignment but slower than SDIO.

        This is automatically selected by board drivers that use SPI.

menu "Internal Storage Configuration"

    config USE_INTERNAL_FLASH_STORAGE
        bool "Use internal flash as storage (LittleFS)"
        default y if BOARD_DRIVER_SEEEDSTUDIO_XIAO_EE02 || BOARD_DRIVER_SEEEDSTUDIO_XIAO_EE04
        default n
        help
            Mounts a LittleFS partition from internal flash to use as storage.
            Disable this if your board has limited flash space (e.g. 4MB)
            and you don't have enough space for a storage partition.
            If disabled, the system will use a small RAM-based filesystem (MemFS)
            for temporary image processing instead.


endmenu
